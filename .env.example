# Required for production deploys.
# Set real values in Vercel project settings; do not commit .env.local.

ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Required on Vercel for persisted edits and production login rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: structured Brandfetch Brand API fallback for brand colors when public
# website detection fails. App still deploys and returns honest null without this.
BRANDFETCH_API_KEY=

# Never commit brokerage credentials, API keys, account exports, or live trading data.
